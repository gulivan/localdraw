# GENERATED FILE — edit backend/src/config/registry/* and run npm run gen:env
# Backend environment variables. Copy to .env and adjust.

# === Server ===
# TCP port the backend HTTP server listens on.
PORT=8000
# Runtime environment; production enables extra validation and hardening.
# Allowed: development, production, test
NODE_ENV=development
# Comma-separated CORS allowlist of frontend origins; also drives HTTPS detection.
# FRONTEND_URL=https://excalidash.example.com
# Express trust proxy setting: true, false, or a positive hop count.
TRUST_PROXY=false
# In-memory drawings list cache TTL in milliseconds.
DRAWINGS_CACHE_TTL_MS=5000
# Number of days to retain drawing snapshots before the hourly sweep prunes them.
SNAPSHOT_RETENTION_DAYS=2
# Maximum size (in MB) of a single uploaded file accepted by multer (imports, database restores).
UPLOAD_MAX_MB=100
# Maximum request body size (in MB) for scene JSON/urlencoded payloads and the Socket.IO buffer; images no longer travel in the scene body (see FILE_UPLOAD_MAX_MB), so this bounds scene JSON only.
BODY_LIMIT_MB=50
# Maximum size (in MB) of a single image accepted by the raw file-upload endpoint (PUT /api/drawings/:id/files/:fileId); the only per-image cap.
FILE_UPLOAD_MAX_MB=100
# Maximum serialized size (in MB) of a tldraw drawing's scene document (its inline data-URL assets included), enforced on create and update; excalidraw drawings are unaffected.
TLDRAW_MAX_SCENE_MB=15

# === Database ===
# Prisma database connection string; file: paths are normalized against prisma/.
DATABASE_URL=file:<backend>/prisma/dev.db
# Prisma datasource provider selected by the docker entrypoint.
# Allowed: sqlite, postgresql
# DATABASE_PROVIDER=sqlite
# Whether the docker entrypoint applies pending migrations on startup.
# RUN_MIGRATIONS=
# Advisory-lock timeout (seconds) used by the migration entrypoint.
# MIGRATION_LOCK_TIMEOUT_SECONDS=

# === Authentication ===
# Authentication mode: local credentials, hybrid, OIDC-enforced, or disabled (no login; every request runs as a single shared local user — do not expose such an instance to untrusted networks).
# Allowed: local, hybrid, oidc_enforced, disabled
AUTH_MODE=local
# Secret used to sign JWTs; an ephemeral random secret is generated in dev when unset.
# JWT_SECRET=change-this-secret-in-production-min-32-chars
# Access-token lifetime (vercel/ms style duration).
JWT_ACCESS_EXPIRES_IN=15m
# Refresh-token lifetime (vercel/ms style duration).
JWT_REFRESH_EXPIRES_IN=7d
# Enable the password-reset flow.
ENABLE_PASSWORD_RESET=false
# Rotate refresh tokens on each successful refresh.
ENABLE_REFRESH_TOKEN_ROTATION=true
# Write authentication/authorization audit-log entries.
ENABLE_AUDIT_LOGGING=false
# Disable the first-run onboarding gate in local-mode production.
DISABLE_ONBOARDING_GATE=false
# Lifetime (ms) of the initial admin bootstrap setup code.
BOOTSTRAP_SETUP_CODE_TTL_MS=900000
# Maximum verification attempts for the bootstrap setup code.
BOOTSTRAP_SETUP_CODE_MAX_ATTEMPTS=10
# Minimum accepted password length.
PASSWORD_MIN_LENGTH=12
# Maximum accepted password length.
PASSWORD_MAX_LENGTH=100
# Require at least one uppercase letter in passwords.
PASSWORD_REQUIRE_UPPERCASE=true
# Require at least one lowercase letter in passwords.
PASSWORD_REQUIRE_LOWERCASE=true
# Require at least one number in passwords.
PASSWORD_REQUIRE_NUMBER=true
# Require at least one symbol in passwords.
PASSWORD_REQUIRE_SYMBOL=true

# === OIDC ===
# OIDC issuer (provider) base URL.
# OIDC_ISSUER_URL=https://auth.example.com/realms/main
# OIDC client identifier.
# OIDC_CLIENT_ID=
# OIDC redirect URI; must be HTTPS in production.
# OIDC_REDIRECT_URI=https://excalidash.example.com/auth/oidc/callback
# Explicit OIDC discovery document URL (overrides issuer-derived path).
# OIDC_DISCOVERY_URL=
# OIDC client secret for confidential clients.
# OIDC_CLIENT_SECRET=
# Display name of the OIDC provider shown in the UI.
OIDC_PROVIDER_NAME=OIDC
# Space-separated OIDC scopes requested during login.
OIDC_SCOPES=openid profile email
# ID-token claim to read the user email from.
OIDC_EMAIL_CLAIM=email
# ID-token claim indicating whether the email is verified.
OIDC_EMAIL_VERIFIED_CLAIM=email_verified
# ID-token claim (key or path) carrying the user's groups.
OIDC_GROUPS_CLAIM=groups
# Comma-separated groups whose members are granted admin.
# OIDC_ADMIN_GROUPS=
# Reject logins whose email is not marked verified.
OIDC_REQUIRE_EMAIL_VERIFIED=true
# Just-in-time provision users on first successful OIDC login.
OIDC_JIT_PROVISIONING=true
# Grant admin to the first user provisioned via OIDC.
OIDC_FIRST_USER_ADMIN=true
# Expected signing algorithm for the ID token.
# Allowed: RS256, RS384, RS512, PS256, PS384, PS512, ES256, ES384, ES512, EdDSA, HS256, HS384, HS512
# OIDC_ID_TOKEN_SIGNED_RESPONSE_ALG=
# Client authentication method used at the token endpoint.
# Allowed: none, client_secret_basic, client_secret_post
# OIDC_TOKEN_ENDPOINT_AUTH_METHOD=

# === Security ===
# Secret used to sign CSRF tokens; a dev fallback is derived when unset.
# CSRF_SECRET=
# Maximum CSRF-token issuances per rate-limit window.
CSRF_MAX_REQUESTS=60
# Maximum general API requests per rate-limit window.
RATE_LIMIT_MAX_REQUESTS=1000
# General API rate-limit window in milliseconds (default 15 minutes); pairs with RATE_LIMIT_MAX_REQUESTS.
RATE_LIMIT_WINDOW_MS=900000
# CSRF-token issuance rate-limit window in milliseconds (default 1 minute); pairs with CSRF_MAX_REQUESTS.
CSRF_RATE_LIMIT_WINDOW_MS=60000
# Maximum agent ops-batch requests (POST /api/drawings/:id/ops) per key/user per window.
AGENT_OPS_RATE_LIMIT_MAX=120
# Agent ops-batch rate-limit window in milliseconds (default 1 minute); pairs with AGENT_OPS_RATE_LIMIT_MAX.
AGENT_OPS_RATE_LIMIT_WINDOW_MS=60000
# Redirect HTTP requests to HTTPS when a secure origin is detected.
ENFORCE_HTTPS_REDIRECT=true
# Pepper mixed into API-key hashes; set before creating keys (see docs).
# API_KEY_HASH_PEPPER=
# Enable verbose CSRF debug logging.
DEBUG_CSRF=false

# === S3 storage ===
# S3 bucket name; setting this enables S3-backed file storage.
# S3_BUCKET=
# S3 region.
S3_REGION=us-east-1
# Custom endpoint for S3-compatible services (MinIO, R2, etc.).
# S3_ENDPOINT=
# Public base URL/CDN for objects; required for non-AWS endpoints.
# S3_PUBLIC_URL=
# Force path-style addressing (required for MinIO).
S3_FORCE_PATH_STYLE=false
# Object-key prefix for stored files; trailing slashes are stripped.
S3_KEY_PREFIX=excalidash
# S3 access key ID; omit to use the ambient IAM credential chain.
# AWS_ACCESS_KEY_ID=
# S3 secret access key; omit to use the ambient IAM credential chain.
# AWS_SECRET_ACCESS_KEY=

# === Backups ===
# Cron expression for scheduled backups; unset disables scheduling.
# BACKUP_SCHEDULE=0 3 * * *
# Directory where database backups are written.
BACKUP_DIR=<backend>/backups
# Number of days to retain backups before pruning.
BACKUP_RETENTION_DAYS=14

# === Update check ===
# Allow outbound requests to GitHub to check for new releases.
UPDATE_CHECK_OUTBOUND=true
# GitHub token used to raise the update-check API rate limit.
# Deprecated aliases: GITHUB_TOKEN
# UPDATE_CHECK_GITHUB_TOKEN=

# === Link sharing ===
# Default lifetime (ms) of edit share links (7 days).
LINK_SHARE_EDIT_DEFAULT_TTL_MS=604800000
# Default lifetime (ms) of view share links (30 days).
LINK_SHARE_VIEW_DEFAULT_TTL_MS=2592000000
# Maximum allowed lifetime (ms) for any share link (90 days).
LINK_SHARE_MAX_TTL_MS=7776000000

# === AI ===
# AI chat-proxy provider: disabled (chat panel hidden), anthropic (Messages API), openai (Chat Completions), custom (any OpenAI-compatible baseUrl), or chatgpt (each user connects their own ChatGPT Plus/Pro subscription via Codex OAuth — billed to the user, no server API key). The admin settings page can override this at runtime.
# Allowed: disabled, anthropic, openai, custom, chatgpt
AI_PROVIDER=disabled
# Provider API key for the AI chat proxy. Server-side only — never shipped to the browser. An env-provided key always wins over a key stored via the admin settings page.
# AI_API_KEY=sk-...
# Override the provider base URL (e.g. an OpenAI-compatible gateway or self-hosted endpoint). Required for AI_PROVIDER=custom; optional otherwise.
# AI_BASE_URL=https://api.openai.com/v1
# Model id the chat proxy requests (e.g. claude-opus-4-8 for anthropic, gpt-4o for openai). Falls back to a provider default when unset.
# AI_MODEL=claude-opus-4-8
# Maximum output tokens the chat proxy requests per model call.
AI_MAX_TOKENS_PER_REQUEST=4096
# Maximum AI chat requests allowed per user within AI_RATE_LIMIT_WINDOW_MS.
AI_RATE_LIMIT_MAX=60
# Rolling window (ms) for the AI chat per-user rate limiter.
AI_RATE_LIMIT_WINDOW_MS=60000
# Codex `client_version` sent to the ChatGPT backend (AI_PROVIDER=chatgpt). The backend gates the available model set on this — bump it toward the current Codex CLI release without a redeploy if models disappear.
AI_CHATGPT_CLIENT_VERSION=0.142.5
# Comma-separated Codex model slugs offered when AI_PROVIDER=chatgpt (first is the default). Falls back to a built-in gpt-5.x list when unset.
# AI_CHATGPT_MODELS=gpt-5.1,gpt-5.1-codex,gpt-5.2
# Override the ChatGPT/Codex OAuth client id. Defaults to the public Codex CLI client. Only change if OpenAI rotates the client.
# AI_CHATGPT_CLIENT_ID=
# Override the ChatGPT OAuth issuer origin (authorize/token endpoints). Defaults to https://auth.openai.com.
# AI_CHATGPT_ISSUER=
# OAuth redirect URI for the Codex loopback flow. Defaults to http://localhost:1455/auth/callback; the connect flow uses manual URL paste so this need not be reachable by the server.
# AI_CHATGPT_REDIRECT_URI=
# Base URL of the ChatGPT-backed Codex responses API. Defaults to https://chatgpt.com/backend-api/codex.
# AI_CHATGPT_CODEX_BASE_URL=
# OAuth scopes requested for the ChatGPT session. Defaults to 'openid profile email offline_access' (offline_access is required for refresh).
# AI_CHATGPT_SCOPE=
# `originator` header/param value identifying the client to OpenAI. Defaults to codex_cli_rs.
# AI_CHATGPT_ORIGINATOR=
